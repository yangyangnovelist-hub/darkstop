{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ../../shared/hooks/audit-log.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "AGENT_NAME=edgecase bash ../../shared/hooks/teardown.sh",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}
