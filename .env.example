# Funded private key for proxy signing (Hardhat dev key)
PROXY_PRIVATE_KEY="983760a4ebf75b2ac3a93531168a0f225d01e5dc6e3568adbd46233ba1fb4fa4"

# # Devnet
# INITIAL_OWNER="0xF4E021377420Afe90c1A7D2b8968904946633a64" # Initial owner address (derived from DEPLOYMENT_PRIVATE_KEY)
# DEPLOYMENT_PRIVATE_KEY="983760a4ebf75b2ac3a93531168a0f225d01e5dc6e3568adbd46233ba1fb4fa4" # Private key for the deployments and contract calls

# Coston
INITIAL_OWNER="0x123.."
DEPLOYMENT_PRIVATE_KEY="123..."

# Docker image registry (defaults to "local" for locally-built images)
# Uncomment to use remote registry:
# REGISTRY=registry.gitlab.com/flarenetwork/tee/e2e

# Chain RPC URL
CHAIN_URL=https://coston2-api.flare.network/ext/C/rpc

# Path to Coston2 deployed contract addresses
ADDRESSES_FILE=./config/coston2/deployed-addresses.json

# Must be false on live networks
LOCAL_MODE=false

# TEE attestation mode: true = use test code hash/platform (no real TEE hardware)
# Set to false when running on actual GCP Confidential VM with real attestation
SIMULATED_TEE=true

# Normal/FTDC proxy URL on Coston2
NORMAL_PROXY_URL=https://tee-proxy-coston2-1.flare.rocks

# Extension proxy URL (local)
# EXT_PROXY_URL=http://localhost:6674
EXT_PROXY_URL=https://<your-ngrok-url>.ngrok-free.dev
